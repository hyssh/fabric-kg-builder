# .env.example — copy to .env and fill in. NEVER commit .env (it is gitignored).
# With DefaultAzureCredential (dev), keys may be omitted if `az login` grants
# the required RBAC roles (see docs/REQUIREMENTS-001-cli-prerequisites.md).
# Endpoints are non-secret but are read from the environment for convenience.

# --- Azure AI Foundry (required) ---
AZURE_AI_FOUNDRY_ENDPOINT=https://example-aiservices.services.ai.azure.com/api/projects/example-project
# AZURE_AI_FOUNDRY_API_KEY=        # optional when using DefaultAzureCredential

# --- Azure OpenAI (AzureOpenAI SDK endpoint — different from Foundry project URL above) ---
AZURE_OPENAI_ENDPOINT=https://example-aiservices.openai.azure.com/
# AZURE_OPENAI_API_KEY=            # optional when using DefaultAzureCredential

# --- Azure AI Document Intelligence ---
AZURE_DOCINTEL_ENDPOINT=https://example-docintell.cognitiveservices.azure.com
# AZURE_DOCINTEL_API_KEY=

# --- Azure AI Search (in MVP) ---
AZURE_SEARCH_ENDPOINT=https://example-search.search.windows.net
# AZURE_SEARCH_API_KEY=

# --- Azure Blob Storage (visual assets) ---
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_SAS_TOKEN=

# --- Service Principal (CI/prod only; dev uses az login) ---
# FABRIC_CLIENT_ID=
# FABRIC_CLIENT_SECRET=
# FABRIC_TENANT_ID=
